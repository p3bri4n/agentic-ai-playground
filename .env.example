# Chemin ABSOLU vers le dossier workspace sur l'HOTE (pas dans un conteneur).
# Requis par mcp-client, qui monte ce chemin dans les conteneurs MCP qu'il
# spawn via le socket Docker (docker run -v <chemin_hote>:/workspace ...).
WORKSPACE_HOST_PATH=/chemin/absolu/vers/workspace

# Chemin vers le dossier contenant les poids des modèles servis (deux
# conventions coexistent selon le backend, voir README section Backend
# d'inférence) : sous-répertoire HuggingFace-style (safetensors + config.json
# + tokenizer) pour le quant EXL3 de TabbyAPI (backend par défaut), fichiers
# .gguf uniques (LLAMA_MODEL_FILE/LLAMA_MMPROJ_FILE plus bas) pour le backend
# alternatif llama-server. Optionnel : si absent, docker compose retombe sur
# ./models (chemin relatif au fichier docker-compose.yml). Utile pour stocker
# les modèles sur un disque séparé (poids volumineux, plusieurs dizaines de
# Go par modèle).
MODELS_HOST_PATH=/chemin/absolu/vers/models


# URL du backend d'inférence (API OpenAI-compatible) utilisée par
# langgraph-agent et context-manager. Optionnel : par défaut, tabbyapi
# (http://tabbyapi:5000/v1 — voir services/tabbyapi/config.yml).
LLM_BASE_URL=http://tabbyapi:5000/v1

# Transmission des screenshots GhostDesk au LLM : vide/absent (défaut)
# reconvertit systématiquement en PNG — le backend par défaut (TabbyAPI/
# ExLlamaV3) n'est pas connu pour décoder le WebP nativement (à vérifier
# empiriquement, voir plan d'implémentation tabbyapi). Mettre "webp"
# uniquement avec le backend alternatif llama-server, dont le fork llama.cpp
# décode le WebP nativement (voir README, tableau des bugs) — jamais avec
# Ollama, dont le décodeur mtmd échoue explicitement sur le WebP.
IMAGE_FORMAT_PASSTHROUGH=

# Qwen3.6 raisonne par défaut sur chaque tour. true (défaut) injecte
# /no_think dans le system prompt quand tous les tool_calls du tour
# précédent sont auto-approuvés (boucle perception-action rapide type
# capture/clic GhostDesk) ; false désactive cette injection, le modèle
# raisonne alors normalement sur tous les tours.
ADAPTIVE_THINKING=true

# Plan explicite (Phase 1 « cœur cognitif », Itération 1 — voir
# docs/briefs/phase-1-coeur-cognitif.md et README, section "Plan explicite").
# false (défaut) : comportement inchangé. true : décompose chaque tâche en
# sous-tâches JSON via un appel LLM dédié avant le premier tour, visible
# dans les logs et le message d'approbation — un appel LLM supplémentaire
# par tâche, à activer explicitement pour mesurer le mécanisme.
PLANNER_ENABLED=false

# Vérification post-action + budget d'échec (Itération 2 — voir
# docs/briefs/phase-1-coeur-cognitif.md et README, section "Plan explicite").
# N'A D'EFFET QUE SI PLANNER_ENABLED=true (rien à vérifier sans plan).
# false (défaut) : comportement inchangé. true : compare le résultat de
# chaque tour d'outils au critère de succès de la sous-tâche active via un
# appel LLM juge dédié — un appel LLM supplémentaire par tour vérifié.
VERIFICATION_ENABLED=false
# Tentatives par sous-tâche avant de la marquer échouée.
SUBTASK_ATTEMPT_BUDGET=3
# Replanifications tolérées avant un rapport d'échec honnête.
REPLAN_BUDGET=2

# Filet de sécurité (voir README, tableau des bugs) : certains modèles
# écrivent parfois leur appel d'outil en prose au lieu d'un tool_calls
# structuré (piégé dans le raisonnement, jamais reconnu par le serveur).
# Nombre de fois où langgraph-agent relance automatiquement le LLM avant
# d'abandonner et d'afficher une notice explicite, une fois la récupération
# de secours (_extract_fallback_tool_call) elle-même infructueuse. Budget
# cumulé pour toute la tâche, comme MAX_TOOL_ITERATIONS.
MAX_EMPTY_ANSWER_RETRIES=1

# Clé fixe pour Open WebUI (sessions de connexion, chiffrement des secrets
# stockés). Sans valeur fixe, chaque recréation du conteneur en génère une
# nouvelle et déconnecte tous les utilisateurs. Générer avec :
#   openssl rand -hex 32
WEBUI_SECRET_KEY=change-moi-avec-openssl-rand-hex-32

# Bearer token MCP et mot de passe VNC pour GhostDesk (bureau virtuel piloté
# par l'agent). Générer chacun avec : openssl rand -hex 32
GHOSTDESK_AUTH_TOKEN=change-moi-avec-openssl-rand-hex-32
GHOSTDESK_VNC_PASSWORD=change-moi-avec-openssl-rand-hex-32

# Espace de coordonnées attendu par GhostDesk pour les clics souris.
# Requis par les modèles Qwen, qui raisonnent nativement en repère normalisé
# 0-1000 plutôt qu'en pixels écran : sans cet en-tête, leurs clics
# atterrissent à côté de leur cible (documenté par GhostDesk). Les modèles
# frontière (Claude, GPT-4o) travaillent nativement en pixels écran ; laisser
# vide (GHOSTDESK_MODEL_SPACE=) pour désactiver l'en-tête si le modèle servi
# change pour l'un d'eux.
GHOSTDESK_MODEL_SPACE=1000

# Bearer token MCP pour ocr-service (OCR d'appoint, find_text/read_screen —
# voir README, section OCR d'appoint). Générer avec : openssl rand -hex 32
OCR_AUTH_TOKEN=change-moi-avec-openssl-rand-hex-32

# Cockpit d'observabilité local (voir README, section Observabilité).
# Port publié sur l'hôte pour le service dashboard.
DASHBOARD_PORT=8090

# Forfait de tokens par image dans la décomposition approximative du
# contexte de langgraph-agent (POST /context) — un compte exact dépendrait
# du tokenizer visuel du modèle servi, hors périmètre pour un simple ordre
# de grandeur affiché sur le dashboard.
IMAGE_TOKEN_ESTIMATE=1500

# VRAM par GPU sur le dashboard (nvidia-smi, panneau "VRAM"). Désactivé par
# défaut : nécessite de décommenter aussi le bloc "deploy" (runtime nvidia)
# du service dashboard dans docker-compose.yml, sans quoi nvidia-smi est
# absent du conteneur et cette section reste à null sur le dashboard.
ENABLE_GPU_STATS=false
