# Chemin ABSOLU vers le dossier workspace sur l'HOTE (pas dans un conteneur).
# Requis par mcp-client, qui monte ce chemin dans les conteneurs MCP qu'il
# spawn via le socket Docker (docker run -v <chemin_hote>:/workspace ...).
WORKSPACE_HOST_PATH=/chemin/absolu/vers/workspace

# Clé fixe pour Open WebUI (sessions de connexion, chiffrement des secrets
# stockés). Sans valeur fixe, chaque recréation du conteneur en génère une
# nouvelle et déconnecte tous les utilisateurs. Générer avec :
#   openssl rand -hex 32
WEBUI_SECRET_KEY=change-moi-avec-openssl-rand-hex-32

# Bearer token MCP et mot de passe VNC pour GhostDesk (bureau virtuel piloté
# par l'agent). Générer chacun avec : openssl rand -hex 32
GHOSTDESK_AUTH_TOKEN=change-moi-avec-openssl-rand-hex-32
GHOSTDESK_VNC_PASSWORD=change-moi-avec-openssl-rand-hex-32
